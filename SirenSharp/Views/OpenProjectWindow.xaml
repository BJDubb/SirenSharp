<ui:FluentWindow x:Class="SirenSharp.Views.OpenProjectWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Open Project" Height="460" Width="520"
        MinHeight="360" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <ui:FluentWindow.Resources>
        <converters:CountToVisibilityConverter xmlns:converters="clr-namespace:SirenSharp.Converters" x:Key="countToVis" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Open Project" ShowMaximize="False" ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="24,8,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Recent projects" Style="{StaticResource SectionHeaderText}" />

            <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0" Padding="6">
                <Grid>
                    <TextBlock Text="No recent projects yet. Use Browse to find a .ssproj file."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" TextAlignment="Center"
                               VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="320"
                               Visibility="{Binding Recents.Count, Converter={StaticResource countToVis}, ConverterParameter=invert}" />

                    <ListBox x:Name="RecentList" ItemsSource="{Binding Recents}"
                             Style="{StaticResource CardListBox}" ItemContainerStyle="{StaticResource CardListBoxItem}"
                             MouseDoubleClick="OnDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Document24" FontSize="18" Margin="0,0,10,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Path}" FontSize="11" Style="{StaticResource MutedText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="24,16,24,20">
            <ui:Button Content="Browse…" Icon="{ui:SymbolIcon FolderOpen24}" Appearance="Secondary"
                       HorizontalAlignment="Left" Click="OnBrowse" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Appearance="Secondary" Margin="0,0,8,0" MinWidth="90"
                           IsCancel="True" Click="OnCancel" />
                <ui:Button Content="Open" Appearance="Primary" MinWidth="90" IsDefault="True" Click="OnOpen" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
